# ============================================================
# Environment Variables — copy this file to .env.local
# and fill in your actual values. NEVER commit .env.local!
# ============================================================

# Supabase (required)
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only — keep secret!)
# Only add this if you need admin/service-role access in server actions.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
