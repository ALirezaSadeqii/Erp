# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# -------------------------------------------------------
# SECRETS & ENVIRONMENT VARIABLES — never commit these!
# -------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
*.env
# .env.example is intentionally NOT ignored — it is safe to commit

# -------------------------------------------------------
# Dependencies
# -------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -------------------------------------------------------
# Next.js build output
# -------------------------------------------------------
/.next/
/out/
/build

# -------------------------------------------------------
# Testing & coverage
# -------------------------------------------------------
/coverage

# -------------------------------------------------------
# Certificates & keys
# -------------------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt

# -------------------------------------------------------
# Debug logs
# -------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# -------------------------------------------------------
# OS & editor artifacts
# -------------------------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/settings.json
*.swp
*.swo

# -------------------------------------------------------
# Vercel / deployment
# -------------------------------------------------------
.vercel

# -------------------------------------------------------
# TypeScript
# -------------------------------------------------------
*.tsbuildinfo
next-env.d.ts
